{
  "cleanUrls": true,
  "trailingSlash": false,
  "routes": [
    {
      "src": "/framework-live",
      "dest": "/gaif-ecosystem-dashboard.html"
    },
    {
      "src": "/gaif-ecosystem-dashboard",
      "dest": "/gaif-ecosystem-dashboard.html"
    }
  ],
  "headers": [
    {
      "source": "/gaif-ecosystem-dashboard.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" },
        { "key": "X-Content-Type-Options", "value": "nosniff" }
      ]
    }
  ]
}
